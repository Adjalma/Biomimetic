# =============================================================================
# Copie este ficheiro para .env (mesma pasta: AI-Biomimetica).
# O .env está no .gitignore — nunca commites chaves.
# A API carrega .env ao arrancar (scripts/run_bio_console_api.py → bio_console_api).
# Se existir ficheiro bio_console.env na mesma pasta, as variáveis dele SOBREPÕEM o .env
# (útil para overrides locais). GET /tts/elevenlabs/status devolve bio_console_env_present.
# =============================================================================

# --- Obsidian (notas Markdown no cofre) ---
# OBSIDIAN_VAULT_ROOT=C:\caminho\absoluto\do\cofre\com\.obsidian
# OBSIDIAN_CHOKMAH_RELATIVE=CHOKMAH
# OBSIDIAN_WRITE_TOKEN=
# Registar automaticamente cada troca do chat no cofre (dialogos/AAAA-MM-DD.md)
# OBSIDIAN_AUTO_LOG_CHAT=true

# --- ElevenLabs (TTS — voz das respostas) ---
# A API KEY é texto tipo sk_... em Profile → API keys (NÃO é um URL do site).
# Voice ID: página da voz (código curto), não o link da voice library.
# Sem aspas; sem espaços em volta do =. Reinicie a API após editar.
# ELEVENLABS_API_KEY=sk_sua_chave_aqui
# ELEVENLABS_VOICE_ID=id_da_voz_aqui
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Menos "robô": troque a voz no painel ElevenLabs; depois afinar prosódia (defaults na API já mais expressivos):
# ELEVENLABS_STABILITY=0.36
# ELEVENLABS_SIMILARITY_BOOST=0.78
# ELEVENLABS_STYLE=0.32
# ELEVENLABS_SPEED=0.97
# ELEVENLABS_USE_SPEAKER_BOOST=true
# Pronúncia PT (ISO 639-1; modelo tem de suportar):
# ELEVENLABS_LANGUAGE_CODE=pt
# Qualidade MP3 / latência (ver docs ElevenLabs):
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=0
# Rede corporativa / SSL: erro CERTIFICATE_VERIFY_FAILED → use o PEM da CA interna:
# ELEVENLABS_CA_BUNDLE=C:\caminho\corp-ca.pem
# ou só em rede confiável (menos seguro):
# ELEVENLABS_SSL_VERIFY=false

# --- Z-API (WhatsApp — envio e webhook) ---
# Painel Z-API: Instance ID, Instance Token, Client-Token
# ZAPI_INSTANCE_ID=
# ZAPI_INSTANCE_TOKEN=
# ZAPI_CLIENT_TOKEN=
# ZAPI_WEBHOOK_SECRET=
# WHATSAPP_ZAPI_AGENT_MODE=true
# WHATSAPP_ZAPI_CHAT_SYSTEM=

# --- Ollama (pode também ir nas Configurações do frontend; env sobrescreve defaults do processo) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b

# --- Bio Console (opcional) ---
# BIO_CONSOLE_HOST=0.0.0.0
# BIO_CONSOLE_PORT=8000
# BIO_CONSOLE_RELOAD=1
# BIO_CONSOLE_EXTRA_CORS_ORIGINS=http://localhost:8080

# --- Agente CHOKMAH (apresentação + evolução — ver docs/bio-console/agente-roadmap.md) ---
# CHOKMAH_AGENT_NAME=CHOKMAH
# CHOKMAH_WELCOME_MESSAGE=Texto fixo (opcional; senão: «Olá. Sou CHOKMAH, o teu agente cognitivo, como posso lhe ajudar?»)
# Registar aberturas de conversa no Obsidian (GET /agent/welcome)
# OBSIDIAN_LOG_AGENT_EVENTS=true

# AGENT_SYSTEM_PROMPT_SUFFIX=
# AGENT_BIOMIMETIC_EVOLVE_EVERY=48
# AGENT_BIOMIMETIC_EVOLVE_COOLDOWN_SEC=900
# AGENT_EVOLUTION_PROFILE=minimal
# AGENT_EVOLUTION_ASYNC=true
